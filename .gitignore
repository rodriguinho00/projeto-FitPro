#  .gitignore

```gitignore
# Ambiente virtual
venv/
env/
ENV/

# Arquivos compilados do Python
__pycache__/
*.pyc
*.pyo
*.pyd

# Arquivos do sistema
.DS_Store
Thumbs.db

# Variáveis de ambiente
.env

# Logs
*.log

# Arquivos do VS Code
.vscode/

# Arquivos do PyCharm
.idea/

# Banco de dados (caso use)
*.db
*.sqlite3

# Arquivos temporários
*.tmp
```
